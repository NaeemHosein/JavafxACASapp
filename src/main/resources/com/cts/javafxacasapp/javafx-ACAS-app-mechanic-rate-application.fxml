<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="750.0" prefWidth="1100.0" style="-fx-background-color: #0f172a;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cts.javafxacasapp.MechanicRateAppController">

    <!-- Top Navigation Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="25.0" style="-fx-background-color: #1e293b;                      -fx-padding: 20 30;                      -fx-border-color: #ef4444;                      -fx-border-width: 0 0 2 0;">

            <Button onAction="#handleBack" style="-fx-background-color: transparent;                            -fx-text-fill: #94a3b8;                            -fx-border-color: #334155;                            -fx-border-radius: 8;                            -fx-background-radius: 8;                            -fx-padding: 10 20;                            -fx-cursor: hand;                            -fx-font-size: 13px;                            -fx-font-weight: 600;" text="← Back to Dashboard" />

            <Region HBox.hgrow="ALWAYS" />

            <VBox alignment="CENTER" spacing="2">
                <Label style="-fx-text-fill: #ef4444;                               -fx-font-size: 20px;                               -fx-font-weight: bold;                               -fx-letter-spacing: 2px;" text="RATE OUR APPLICATION" />
                <Label style="-fx-text-fill: #64748b;                               -fx-font-size: 11px;" text="Share your experience with ACAS" />
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

         <Label fx:id="lblUser" style="-fx-text-fill: #cbd5e1;                           -fx-font-size: 13px;" text="Guest User" />
         <Label fx:id="lblRole" style="-fx-text-fill: #cbd5e1;                           -fx-font-size: 13px;" text="Role" />
        </HBox>
    </top>

    <!-- Main Content -->
    <center>
        <VBox alignment="CENTER" spacing="30" style="-fx-background-color: #0f172a; -fx-padding: 60 200;">

            <!-- Rating Card -->
            <VBox spacing="25" style="-fx-background-color: #1e293b;                          -fx-background-radius: 12;                          -fx-padding: 40;                          -fx-border-color: #334155;                          -fx-border-width: 1;                          -fx-border-radius: 12;">

                <!-- Star Rating Section -->
                <VBox alignment="CENTER" spacing="12">
                    <Label style="-fx-text-fill: #ef4444;                                   -fx-font-size: 14px;                                   -fx-font-weight: bold;                                   -fx-letter-spacing: 1.5;" text="YOUR RATING" />

                    <Label fx:id="lblRatingText" style="-fx-text-fill: #64748b;                                   -fx-font-size: 13px;" text="Click a star to rate" />

                    <!-- Star Buttons -->
                    <HBox alignment="CENTER" spacing="10">
                        <Button fx:id="btnStar1" onAction="#handleStar1" style="-fx-background-color: transparent;                                        -fx-text-fill: #334155;                                        -fx-font-size: 42px;                                        -fx-cursor: hand;                                        -fx-padding: 0;" text="★" />
                        <Button fx:id="btnStar2" onAction="#handleStar2" style="-fx-background-color: transparent;                                        -fx-text-fill: #334155;                                        -fx-font-size: 42px;                                        -fx-cursor: hand;                                        -fx-padding: 0;" text="★" />
                        <Button fx:id="btnStar3" onAction="#handleStar3" style="-fx-background-color: transparent;                                        -fx-text-fill: #334155;                                        -fx-font-size: 42px;                                        -fx-cursor: hand;                                        -fx-padding: 0;" text="★" />
                        <Button fx:id="btnStar4" onAction="#handleStar4" style="-fx-background-color: transparent;                                        -fx-text-fill: #334155;                                        -fx-font-size: 42px;                                        -fx-cursor: hand;                                        -fx-padding: 0;" text="★" />
                        <Button fx:id="btnStar5" onAction="#handleStar5" style="-fx-background-color: transparent;                                        -fx-text-fill: #334155;                                        -fx-font-size: 42px;                                        -fx-cursor: hand;                                        -fx-padding: 0;" text="★" />
                    </HBox>
                </VBox>

                <Separator style="-fx-background-color: #334155;" />

                <!-- Feedback Section -->
                <VBox spacing="10">
                    <Label style="-fx-text-fill: #ef4444;                                   -fx-font-size: 14px;                                   -fx-font-weight: bold;                                   -fx-letter-spacing: 1.5;" text="YOUR FEEDBACK" />
                    <Label style="-fx-text-fill: #64748b; -fx-font-size: 12px;" text="Tell us what you think and how we can improve!" />
                    <TextArea fx:id="txtFeedback" prefRowCount="6" promptText="Write your feedback here..." style="-fx-background-color: #0f172a; -fx-text-fill: black; -fx-border-color: #475569; -fx-border-radius: 8; -fx-background-radius: 8; -fx-prompt-text-fill: #64748b; -fx-font-size: 13px; -fx-padding: 12;" wrapText="true" />
                </VBox>

                <Separator style="-fx-background-color: #334155;" />

                <!-- Submit Button -->
                <HBox alignment="CENTER" spacing="15">
                    <Button onAction="#handleClear" style="-fx-background-color: transparent;                                    -fx-text-fill: #94a3b8;                                    -fx-border-color: #334155;                                    -fx-border-radius: 8;                                    -fx-background-radius: 8;                                    -fx-padding: 12 30;                                    -fx-cursor: hand;                                    -fx-font-size: 13px;" text="Clear" />
                    <Button onAction="#handleSubmit" style="-fx-background-color: #ef4444;                                    -fx-text-fill: white;                                    -fx-border-radius: 8;                                    -fx-background-radius: 8;                                    -fx-padding: 12 40;                                    -fx-cursor: hand;                                    -fx-font-size: 13px;                                    -fx-font-weight: 600;" text="Submit Rating" />
                </HBox>

            </VBox>
        </VBox>
    </center>

    <!-- Bottom Status Bar -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #1e293b;                      -fx-padding: 15 30;                      -fx-border-color: #334155;                      -fx-border-width: 1 0 0 0;">
            <Circle fx:id="statusIndicator" radius="5" style="-fx-fill: #10b981;" />
            <Label fx:id="lblStatus" style="-fx-text-fill: #cbd5e1;                           -fx-font-size: 12px;                           -fx-font-weight: 500;" text="Select a star rating and leave your feedback" />
            <Region HBox.hgrow="ALWAYS" />
        </HBox>
    </bottom>

</BorderPane>
