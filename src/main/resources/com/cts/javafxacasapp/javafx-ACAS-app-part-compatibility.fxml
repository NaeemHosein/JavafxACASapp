<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Line?>

<BorderPane prefHeight="750.0" prefWidth="1100.0" style="-fx-background-color: #0f172a;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cts.javafxacasapp.PartCompatibilityController">

    <!-- Top Navigation Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="25.0" style="-fx-background-color: #1e293b;                      -fx-padding: 20 30;                      -fx-border-color: #ef4444;                      -fx-border-width: 0 0 2 0;">

            <!-- Back Button -->
            <Button onAction="#handleBack" style="-fx-background-color: transparent;                            -fx-text-fill: #94a3b8;                            -fx-border-color: #334155;                            -fx-border-radius: 8;                            -fx-background-radius: 8;                            -fx-padding: 10 20;                            -fx-cursor: hand;                            -fx-font-size: 13px;                            -fx-font-weight: 600;" text="← Back to Dashboard">
            </Button>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Title -->
            <VBox alignment="CENTER" spacing="2">
                <Label style="-fx-text-fill: #ef4444;                               -fx-font-size: 20px;                               -fx-font-weight: bold;                               -fx-letter-spacing: 2px;" text="PART COMPATIBILITY CHECK">
                </Label>
                <Label style="-fx-text-fill: #64748b;                               -fx-font-size: 11px;" text="Verify if a part is compatible with your vehicle">
                </Label>
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <Label fx:id="lblUser" style="-fx-text-fill: #cbd5e1;                           -fx-font-size: 13px;" text="Guest User">
            </Label>
         <Label fx:id="lblRole" layoutX="1017.0" layoutY="45.0" style="-fx-text-fill: #cbd5e1;                           -fx-font-size: 13px;" text="Role" />
        </HBox>
    </top>

    <!-- Main Content -->
    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: #0f172a; -fx-background: #0f172a;">
            <VBox alignment="TOP_CENTER" spacing="30.0">
                <padding>
                    <Insets bottom="40.0" left="60.0" right="60.0" top="40.0" />
                </padding>

                <!-- Vehicle Information Section -->
                <VBox maxWidth="800" spacing="20" style="-fx-background-color: #1e293b;                              -fx-background-radius: 12;                              -fx-padding: 30;                              -fx-border-color: #334155;                              -fx-border-width: 1;                              -fx-border-radius: 12;">

                    <Label style="-fx-text-fill: #ef4444;                                   -fx-font-size: 14px;                                   -fx-font-weight: bold;                                   -fx-letter-spacing: 1.5;" text="YOUR VEHICLE">
                    </Label>

                    <Separator style="-fx-background-color: #334155;" />

                    <GridPane hgap="20" vgap="18">
                        <!-- Make -->
                        <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label style="-fx-text-fill: #cbd5e1;                                           -fx-font-size: 12px;                                           -fx-font-weight: 600;" text="Make">
                            </Label>
                            <ComboBox fx:id="cmbMake" onAction="#handleVehicleFieldChange" prefWidth="250" promptText="Select make" style="-fx-background-color: #0f172a; -fx-text-fill: #ffffff; -fx-border-color: #475569; -fx-border-radius: 8; -fx-background-radius: 8;">
                            </ComboBox>
                        </VBox>

                        <!-- Model -->
                        <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label style="-fx-text-fill: #cbd5e1;                                           -fx-font-size: 12px;                                           -fx-font-weight: 600;" text="Model">
                            </Label>
                            <ComboBox fx:id="cmbModel" onAction="#handleVehicleFieldChange" prefWidth="250" promptText="Select model" style="-fx-background-color: #0f172a; -fx-text-fill: #ffffff; -fx-border-color: #475569; -fx-border-radius: 8; -fx-background-radius: 8;">
                            </ComboBox>
                        </VBox>

                        <!-- Year -->
                        <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label style="-fx-text-fill: #cbd5e1;                                           -fx-font-size: 12px;                                           -fx-font-weight: 600;" text="Year">
                            </Label>
                            <ComboBox fx:id="cmbYear" onAction="#handleVehicleFieldChange" prefWidth="250" promptText="Select year" style="-fx-background-color: #0f172a; -fx-text-fill: #ffffff; -fx-border-color: #475569; -fx-border-radius: 8; -fx-background-radius: 8;">
                            </ComboBox>
                        </VBox>

                        <!-- Engine Type -->
                        <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label style="-fx-text-fill: #cbd5e1;                                           -fx-font-size: 12px;                                           -fx-font-weight: 600;" text="Engine Type">
                            </Label>
                            <ComboBox fx:id="cmbEngineType" onAction="#handleVehicleFieldChange" prefWidth="250" promptText="Select engine" style="-fx-background-color: #0f172a; -fx-text-fill: #ffffff; -fx-border-color: #475569; -fx-border-radius: 8; -fx-background-radius: 8;">
                            </ComboBox>
                        </VBox>
                  <columnConstraints>
                     <ColumnConstraints />
                     <ColumnConstraints />
                  </columnConstraints>
                  <rowConstraints>
                     <RowConstraints />
                     <RowConstraints />
                  </rowConstraints>
                    </GridPane>
                </VBox>

                <!-- Part Search Section -->
                <VBox maxWidth="800" spacing="20" style="-fx-background-color: #1e293b;                              -fx-background-radius: 12;                              -fx-padding: 30;                              -fx-border-color: #334155;                              -fx-border-width: 1;                              -fx-border-radius: 12;">

                    <Label style="-fx-text-fill: #ef4444;                                   -fx-font-size: 14px;                                   -fx-font-weight: bold;                                   -fx-letter-spacing: 1.5;" text="PART INFORMATION">
                    </Label>

                    <Separator style="-fx-background-color: #334155;" />

                    <!-- Search by Part Name or Number -->
                    <VBox spacing="8">
                        <Label style="-fx-text-fill: #cbd5e1;                                       -fx-font-size: 12px;                                       -fx-font-weight: 600;" text="Search by Part Name or Part Number">
                        </Label>
                        <HBox spacing="15">
                            <TextField fx:id="txtPartSearch" prefWidth="600" promptText="e.g., 'Spark Plug' or 'NGK BKR5E'" style="-fx-background-color: #0f172a;                                              -fx-text-fill: #e2e8f0;                                              -fx-border-color: #475569;                                              -fx-border-radius: 8;                                              -fx-background-radius: 8;                                              -fx-prompt-text-fill: #64748b;                                              -fx-padding: 12;">
                            </TextField>
                            <Button onAction="#handleSearchParts" style="-fx-background-color: #ef4444;                                            -fx-text-fill: white;                                            -fx-border-radius: 8;                                            -fx-background-radius: 8;                                            -fx-padding: 12 24;                                            -fx-cursor: hand;                                            -fx-font-size: 13px;                                            -fx-font-weight: 600;" text="Search Parts">
                            </Button>
                        </HBox>
                    </VBox>

                    <!-- OR Divider -->
                    <HBox alignment="CENTER" spacing="15">
                        <Line endX="200" style="-fx-stroke: #334155;" />
                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 12px;" text="OR" />
                        <Line endX="200" style="-fx-stroke: #334155;" />
                    </HBox>

                    <!-- Part Type Selection -->
                    <VBox spacing="15">
                        <Label style="-fx-text-fill: #cbd5e1;                                       -fx-font-size: 12px;                                       -fx-font-weight: 600;" text="Browse by Part Type">
                        </Label>
                        <HBox spacing="15">
                            <ComboBox fx:id="cmbPartType" prefWidth="600" promptText="Select part type to see all compatible parts" style="-fx-background-color: #0f172a;                                             -fx-text-fill: #e2e8f0;                                             -fx-border-color: #475569;                                             -fx-border-radius: 8;                                             -fx-background-radius: 8;">
                            </ComboBox>
                            <Button onAction="#handleBrowseByType" style="-fx-background-color: #ef4444;                                            -fx-text-fill: white;                                            -fx-border-radius: 8;                                            -fx-background-radius: 8;                                            -fx-padding: 12 24;                                            -fx-cursor: hand;                                            -fx-font-size: 13px;                                            -fx-font-weight: 600;" text="Browse Type">
                            </Button>
                        </HBox>
                    </VBox>

                    <!-- Show All Compatible Parts Button -->
                    <HBox alignment="CENTER" spacing="15">
                        <Separator style="-fx-background-color: #334155;" HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleShowAllParts" style="-fx-background-color: transparent;                                        -fx-text-fill: #60a5fa;                                        -fx-border-color: #3b82f6;                                        -fx-border-width: 2;                                        -fx-border-radius: 8;                                        -fx-background-radius: 8;                                        -fx-padding: 12 24;                                        -fx-cursor: hand;                                        -fx-font-size: 13px;                                        -fx-font-weight: 600;" text="Show All Compatible Parts for My Vehicle">
                        </Button>
                        <Separator style="-fx-background-color: #334155;" HBox.hgrow="ALWAYS" />
                    </HBox>
                </VBox>

                <!-- Results Section -->
                <VBox fx:id="resultsSection" managed="false" maxWidth="800" spacing="20" style="-fx-background-color: #1e293b;                              -fx-background-radius: 12;                              -fx-padding: 30;                              -fx-border-color: #10b981;                              -fx-border-width: 2;                              -fx-border-radius: 12;" visible="false">

                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Label style="-fx-text-fill: #10b981;                                       -fx-font-size: 14px;                                       -fx-font-weight: bold;                                       -fx-letter-spacing: 1.5;" text="COMPATIBILITY RESULTS">
                        </Label>
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblResultCount" style="-fx-text-fill: #cbd5e1;                                       -fx-font-size: 13px;                                       -fx-font-weight: 600;" text="0 parts found">
                        </Label>
                    </HBox>

                    <Separator style="-fx-background-color: #334155;" />

                    <!-- Results Table -->
                    <TableView fx:id="tblResults" prefHeight="300" style="-fx-background-color: #0f172a;                                      -fx-border-color: #475569;                                      -fx-border-radius: 8;">
                        <columns>
                            <TableColumn fx:id="colPartName" prefWidth="220" text="Part Name" />
                            <TableColumn fx:id="colPartType" prefWidth="140" text="Type" />
                            <TableColumn fx:id="colCompatible" prefWidth="120" text="Compatible" />
                            <TableColumn fx:id="colYearRange" prefWidth="150" text="Year Range" />
                            <TableColumn fx:id="colEngineType" prefWidth="110" text="Engine" />
                        </columns>
                    </TableView>

                    <!-- Action Buttons -->
                    <HBox alignment="CENTER" spacing="15">
                        <Button onAction="#handleClearResults" style="-fx-background-color: transparent;                                        -fx-text-fill: #94a3b8;                                        -fx-border-color: #475569;                                        -fx-border-width: 2;                                        -fx-border-radius: 8;                                        -fx-background-radius: 8;                                        -fx-padding: 10 24;                                        -fx-cursor: hand;                                        -fx-font-size: 13px;" text="Clear Results">
                        </Button>
                    </HBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <!-- Bottom Status Bar -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #1e293b;                      -fx-padding: 15 30;                      -fx-border-color: #334155;                      -fx-border-width: 1 0 0 0;">

            <Circle fx:id="statusIndicator" radius="5" style="-fx-fill: #10b981;" />
            <Label fx:id="lblStatus" style="-fx-text-fill: #cbd5e1;                           -fx-font-size: 12px;                           -fx-font-weight: 500;" text="Enter vehicle details to check compatibility">
            </Label>

            <Region HBox.hgrow="ALWAYS" />
        </HBox>
    </bottom>

</BorderPane>
