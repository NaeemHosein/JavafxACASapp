<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="750.0" prefWidth="1100.0" style="-fx-background-color: #0f172a;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cts.javafxacasapp.PartCompatibilityController">

    <!-- Top Navigation Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="25.0" style="-fx-background-color: #1e293b;                      -fx-padding: 20 30;                      -fx-border-color: #ef4444;                      -fx-border-width: 0 0 2 0;">

            <!-- Back Button -->
            <Button onAction="#handleBack" style="-fx-background-color: transparent;                            -fx-text-fill: #94a3b8;                            -fx-border-color: #334155;                            -fx-border-radius: 8;                            -fx-background-radius: 8;                            -fx-padding: 10 20;                            -fx-cursor: hand;                            -fx-font-size: 13px;                            -fx-font-weight: 600;" text="← Back to Dashboard">
            </Button>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Title -->
            <VBox alignment="CENTER" spacing="2">
                <Label style="-fx-text-fill: #ef4444;                               -fx-font-size: 20px;                               -fx-font-weight: bold;                               -fx-letter-spacing: 2px;" text="PART COMPATIBILITY CHECK">
                </Label>
                <Label style="-fx-text-fill: #64748b;                               -fx-font-size: 11px;" text="Verify if a part is compatible with your registered vehicle">
                </Label>
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <Label fx:id="lblUser" style="-fx-text-fill: #cbd5e1;                           -fx-font-size: 13px;" text="Guest User">
            </Label>
            <Label fx:id="lblRole" layoutX="1017.0" layoutY="45.0" style="-fx-text-fill: #cbd5e1;                           -fx-font-size: 13px;" text="Role" />
        </HBox>
    </top>

    <!-- Main Content -->
    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: #0f172a; -fx-background: #0f172a;">
            <VBox alignment="TOP_CENTER" spacing="30.0">
                <padding>
                    <Insets bottom="40.0" left="60.0" right="60.0" top="40.0" />
                </padding>

                <!-- Part Search Section -->
                <VBox maxWidth="800" spacing="20" style="-fx-background-color: #1e293b;                              -fx-background-radius: 12;                              -fx-padding: 30;                              -fx-border-color: #334155;                              -fx-border-width: 1;                              -fx-border-radius: 12;">

                    <Label style="-fx-text-fill: #ef4444;                                   -fx-font-size: 14px;                                   -fx-font-weight: bold;                                   -fx-letter-spacing: 1.5;" text="PART INFORMATION">
                    </Label>

                    <Separator style="-fx-background-color: #334155;" />

                    <!-- Search by Part Name or Number -->
                    <VBox spacing="8">
                        <Label style="-fx-text-fill: #cbd5e1;                                       -fx-font-size: 12px;                                       -fx-font-weight: 600;" text="Search by Part Name or Part Number">
                        </Label>
                        <HBox spacing="15">
                            <ComboBox fx:id="cmbPartName" editable="true" prefHeight="46.0" prefWidth="583.0" promptText="e.g Spark Plug or 'NGK IFR6T11'" style="-fx-background-color: #0f172a; -fx-text-fill: #ffffff; -fx-border-color: #475569; -fx-border-radius: 8; -fx-background-radius: 8;" />
                            <Button onAction="#handleSearchParts" style="-fx-background-color: #ef4444;                                            -fx-text-fill: white;                                            -fx-border-radius: 8;                                            -fx-background-radius: 8;                                            -fx-padding: 12 24;                                            -fx-cursor: hand;                                            -fx-font-size: 13px;                                            -fx-font-weight: 600;" text="Search Parts">
                            </Button>
                        </HBox>
                    </VBox>

                    <!-- OR Divider -->
                    <HBox alignment="CENTER" spacing="15" />

                    <!-- Part Type Selection -->
                    <VBox spacing="15">
                        <HBox spacing="15" />
                    </VBox>

                    <!-- Show All Compatible Parts Button -->
                    <HBox alignment="CENTER" spacing="15">
                        <Separator style="-fx-background-color: #334155;" HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleGetCompatibilityStatus" style="-fx-background-color: transparent;                                        -fx-text-fill: #60a5fa;                                        -fx-border-color: #3b82f6;                                        -fx-border-width: 2;                                        -fx-border-radius: 8;                                        -fx-background-radius: 8;                                        -fx-padding: 12 24;                                        -fx-cursor: hand;                                        -fx-font-size: 13px;                                        -fx-font-weight: 600;" text="Get Compatibility Status">
                        </Button>
                        <Separator style="-fx-background-color: #334155;" HBox.hgrow="ALWAYS" />
                    </HBox>
                </VBox>

                <!-- Results Section -->
                <VBox fx:id="resultsSection" managed="false" maxWidth="Infinity" spacing="20" style="-fx-background-color: #1e293b;              -fx-background-radius: 12;              -fx-padding: 30;              -fx-border-color: #10b981;              -fx-border-width: 2;              -fx-border-radius: 12;" visible="false" VBox.vgrow="ALWAYS">

                    <!-- Header -->
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Label style="-fx-text-fill: #10b981;                       -fx-font-size: 14px;                       -fx-font-weight: bold;" text="COMPATIBILITY RESULTS" />
                        <Region HBox.hgrow="ALWAYS" />
                    </HBox>

                    <Separator style="-fx-background-color: #334155;" />

                    <!-- Result Area -->
                    <Label fx:id="lblCompatibilityResult" maxHeight="-Infinity" maxWidth="Infinity" minHeight="-Infinity" prefHeight="200.0" style="-fx-text-fill: white; -fx-font-size: 14px;" wrapText="true" VBox.vgrow="ALWAYS" />


                    <!-- Buttons -->
                    <HBox alignment="CENTER">
                        <Button onAction="#handleClearResults" style="-fx-background-color: transparent;                        -fx-text-fill: #94a3b8;                        -fx-border-color: #475569;                        -fx-border-width: 2;                        -fx-border-radius: 8;                        -fx-background-radius: 8;                        -fx-padding: 10 24;                        -fx-cursor: hand;" text="Clear Results" />
                    </HBox>

                </VBox>
            </VBox>
        </ScrollPane>
    </center>

    <!-- Bottom Status Bar -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #1e293b;                      -fx-padding: 15 30;                      -fx-border-color: #334155;                      -fx-border-width: 1 0 0 0;">

            <Circle fx:id="statusIndicator" radius="5" style="-fx-fill: #10b981;" />
            <Label fx:id="lblStatus" style="-fx-text-fill: #cbd5e1;                           -fx-font-size: 12px;                           -fx-font-weight: 500;" text="Enter vehicle details to check compatibility">
            </Label>

            <Region HBox.hgrow="ALWAYS" />
        </HBox>
    </bottom>

</BorderPane>
