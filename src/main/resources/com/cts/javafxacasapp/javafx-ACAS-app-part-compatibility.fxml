<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cts.javafxacasapp.PartCompatibilityController"
            prefHeight="750.0" prefWidth="1100.0"
            style="-fx-background-color: #0f172a;">

    <!-- Top Navigation Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="25.0"
              style="-fx-background-color: #1e293b;
                     -fx-padding: 20 30;
                     -fx-border-color: #ef4444;
                     -fx-border-width: 0 0 2 0;">

            <!-- Back Button -->
            <Button text="← Back to Dashboard" onAction="#handleBack"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #94a3b8;
                           -fx-border-color: #334155;
                           -fx-border-radius: 8;
                           -fx-background-radius: 8;
                           -fx-padding: 10 20;
                           -fx-cursor: hand;
                           -fx-font-size: 13px;
                           -fx-font-weight: 600;">
            </Button>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Title -->
            <VBox alignment="CENTER" spacing="2">
                <Label text="PART COMPATIBILITY CHECK"
                       style="-fx-text-fill: #ef4444;
                              -fx-font-size: 20px;
                              -fx-font-weight: bold;
                              -fx-letter-spacing: 2px;">
                </Label>
                <Label text="Verify if parts are compatible with your vehicle"
                       style="-fx-text-fill: #64748b;
                              -fx-font-size: 11px;">
                </Label>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="lblUser" text="Guest User"
                   style="-fx-text-fill: #cbd5e1;
                          -fx-font-size: 13px;">
            </Label>
        </HBox>
    </top>

    <!-- Main Content -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true"
                    style="-fx-background-color: #0f172a; -fx-background: #0f172a;">
            <VBox spacing="30.0" alignment="TOP_CENTER">
                <padding>
                    <Insets top="40.0" right="60.0" bottom="40.0" left="60.0"/>
                </padding>

                <!-- Vehicle Information Section -->
                <VBox spacing="20" maxWidth="800"
                      style="-fx-background-color: #1e293b;
                             -fx-background-radius: 12;
                             -fx-padding: 30;
                             -fx-border-color: #334155;
                             -fx-border-width: 1;
                             -fx-border-radius: 12;">

                    <Label text="YOUR VEHICLE"
                           style="-fx-text-fill: #ef4444;
                                  -fx-font-size: 14px;
                                  -fx-font-weight: bold;
                                  -fx-letter-spacing: 1.5;">
                    </Label>

                    <Separator style="-fx-background-color: #334155;"/>

                    <GridPane hgap="20" vgap="18">
                        <!-- Make -->
                        <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Make"
                                   style="-fx-text-fill: #cbd5e1;
                                          -fx-font-size: 12px;
                                          -fx-font-weight: 600;">
                            </Label>
                            <ComboBox fx:id="cmbMake" prefWidth="250"
                                      promptText="Select make"
                                      onAction="#handleVehicleFieldChange"
                                      style="-fx-background-color: #0f172a;
                                            -fx-text-fill: #e2e8f0;
                                            -fx-border-color: #475569;
                                            -fx-border-radius: 8;
                                            -fx-background-radius: 8;">
                            </ComboBox>
                        </VBox>

                        <!-- Model -->
                        <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Model"
                                   style="-fx-text-fill: #cbd5e1;
                                          -fx-font-size: 12px;
                                          -fx-font-weight: 600;">
                            </Label>
                            <ComboBox fx:id="cmbModel" prefWidth="250"
                                      promptText="Select model"
                                      onAction="#handleVehicleFieldChange"
                                      style="-fx-background-color: #0f172a;
                                            -fx-text-fill: #e2e8f0;
                                            -fx-border-color: #475569;
                                            -fx-border-radius: 8;
                                            -fx-background-radius: 8;">
                            </ComboBox>
                        </VBox>

                        <!-- Year -->
                        <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Year"
                                   style="-fx-text-fill: #cbd5e1;
                                          -fx-font-size: 12px;
                                          -fx-font-weight: 600;">
                            </Label>
                            <ComboBox fx:id="cmbYear" prefWidth="250"
                                      promptText="Select year"
                                      onAction="#handleVehicleFieldChange"
                                      style="-fx-background-color: #0f172a;
                                            -fx-text-fill: #e2e8f0;
                                            -fx-border-color: #475569;
                                            -fx-border-radius: 8;
                                            -fx-background-radius: 8;">
                            </ComboBox>
                        </VBox>

                        <!-- Engine Type -->
                        <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="Engine Type"
                                   style="-fx-text-fill: #cbd5e1;
                                          -fx-font-size: 12px;
                                          -fx-font-weight: 600;">
                            </Label>
                            <ComboBox fx:id="cmbEngineType" prefWidth="250"
                                      promptText="Select engine"
                                      onAction="#handleVehicleFieldChange"
                                      style="-fx-background-color: #0f172a;
                                            -fx-text-fill: #e2e8f0;
                                            -fx-border-color: #475569;
                                            -fx-border-radius: 8;
                                            -fx-background-radius: 8;">
                            </ComboBox>
                        </VBox>
                    </GridPane>
                </VBox>

                <!-- Part Search Section -->
                <VBox spacing="20" maxWidth="800"
                      style="-fx-background-color: #1e293b;
                             -fx-background-radius: 12;
                             -fx-padding: 30;
                             -fx-border-color: #334155;
                             -fx-border-width: 1;
                             -fx-border-radius: 12;">

                    <Label text="PART INFORMATION"
                           style="-fx-text-fill: #ef4444;
                                  -fx-font-size: 14px;
                                  -fx-font-weight: bold;
                                  -fx-letter-spacing: 1.5;">
                    </Label>

                    <Separator style="-fx-background-color: #334155;"/>

                    <!-- Search by Part Name or Number -->
                    <VBox spacing="8">
                        <Label text="Search by Part Name or Part Number"
                               style="-fx-text-fill: #cbd5e1;
                                      -fx-font-size: 12px;
                                      -fx-font-weight: 600;">
                        </Label>
                        <HBox spacing="15">
                            <TextField fx:id="txtPartSearch" prefWidth="600"
                                       promptText="e.g., 'Spark Plug' or 'NGK BKR5E'"
                                       style="-fx-background-color: #0f172a;
                                             -fx-text-fill: #e2e8f0;
                                             -fx-border-color: #475569;
                                             -fx-border-radius: 8;
                                             -fx-background-radius: 8;
                                             -fx-prompt-text-fill: #64748b;
                                             -fx-padding: 12;">
                            </TextField>
                            <Button text="Search Parts" onAction="#handleSearchParts"
                                    style="-fx-background-color: #ef4444;
                                           -fx-text-fill: white;
                                           -fx-border-radius: 8;
                                           -fx-background-radius: 8;
                                           -fx-padding: 12 24;
                                           -fx-cursor: hand;
                                           -fx-font-size: 13px;
                                           -fx-font-weight: 600;">
                            </Button>
                        </HBox>
                    </VBox>

                    <!-- OR Divider -->
                    <HBox alignment="CENTER" spacing="15">
                        <Line endX="200" style="-fx-stroke: #334155;"/>
                        <Label text="OR" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                        <Line endX="200" style="-fx-stroke: #334155;"/>
                    </HBox>

                    <!-- Part Type Selection -->
                    <VBox spacing="15">
                        <Label text="Browse by Part Type"
                               style="-fx-text-fill: #cbd5e1;
                                      -fx-font-size: 12px;
                                      -fx-font-weight: 600;">
                        </Label>
                        <HBox spacing="15">
                            <ComboBox fx:id="cmbPartType" prefWidth="600"
                                      promptText="Select part type to see all compatible parts"
                                      style="-fx-background-color: #0f172a;
                                            -fx-text-fill: #e2e8f0;
                                            -fx-border-color: #475569;
                                            -fx-border-radius: 8;
                                            -fx-background-radius: 8;">
                            </ComboBox>
                            <Button text="Browse Type" onAction="#handleBrowseByType"
                                    style="-fx-background-color: #ef4444;
                                           -fx-text-fill: white;
                                           -fx-border-radius: 8;
                                           -fx-background-radius: 8;
                                           -fx-padding: 12 24;
                                           -fx-cursor: hand;
                                           -fx-font-size: 13px;
                                           -fx-font-weight: 600;">
                            </Button>
                        </HBox>
                    </VBox>

                    <!-- Show All Compatible Parts Button -->
                    <HBox alignment="CENTER" spacing="15">
                        <Separator HBox.hgrow="ALWAYS" style="-fx-background-color: #334155;"/>
                        <Button text="Show All Compatible Parts for My Vehicle" onAction="#handleShowAllParts"
                                style="-fx-background-color: transparent;
                                       -fx-text-fill: #60a5fa;
                                       -fx-border-color: #3b82f6;
                                       -fx-border-width: 2;
                                       -fx-border-radius: 8;
                                       -fx-background-radius: 8;
                                       -fx-padding: 12 24;
                                       -fx-cursor: hand;
                                       -fx-font-size: 13px;
                                       -fx-font-weight: 600;">
                        </Button>
                        <Separator HBox.hgrow="ALWAYS" style="-fx-background-color: #334155;"/>
                    </HBox>
                </VBox>

                <!-- Results Section -->
                <VBox fx:id="resultsSection" spacing="20" maxWidth="800" visible="false" managed="false"
                      style="-fx-background-color: #1e293b;
                             -fx-background-radius: 12;
                             -fx-padding: 30;
                             -fx-border-color: #10b981;
                             -fx-border-width: 2;
                             -fx-border-radius: 12;">

                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Label text="COMPATIBILITY RESULTS"
                               style="-fx-text-fill: #10b981;
                                      -fx-font-size: 14px;
                                      -fx-font-weight: bold;
                                      -fx-letter-spacing: 1.5;">
                        </Label>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblResultCount" text="0 parts found"
                               style="-fx-text-fill: #cbd5e1;
                                      -fx-font-size: 13px;
                                      -fx-font-weight: 600;">
                        </Label>
                    </HBox>

                    <Separator style="-fx-background-color: #334155;"/>

                    <!-- Results Table -->
                    <TableView fx:id="tblResults" prefHeight="300"
                               style="-fx-background-color: #0f172a;
                                     -fx-border-color: #475569;
                                     -fx-border-radius: 8;">
                        <columns>
                            <TableColumn fx:id="colPartName" text="Part Name" prefWidth="220"/>
                            <TableColumn fx:id="colPartType" text="Type" prefWidth="140"/>
                            <TableColumn fx:id="colCompatible" text="Compatible" prefWidth="120"/>
                            <TableColumn fx:id="colYearRange" text="Year Range" prefWidth="150"/>
                            <TableColumn fx:id="colEngineType" text="Engine" prefWidth="110"/>
                        </columns>
                    </TableView>

                    <!-- Action Buttons -->
                    <HBox spacing="15" alignment="CENTER">
                        <Button text="Clear Results" onAction="#handleClearResults"
                                style="-fx-background-color: transparent;
                                       -fx-text-fill: #94a3b8;
                                       -fx-border-color: #475569;
                                       -fx-border-width: 2;
                                       -fx-border-radius: 8;
                                       -fx-background-radius: 8;
                                       -fx-padding: 10 24;
                                       -fx-cursor: hand;
                                       -fx-font-size: 13px;">
                        </Button>
                    </HBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <!-- Bottom Status Bar -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="15.0"
              style="-fx-background-color: #1e293b;
                     -fx-padding: 15 30;
                     -fx-border-color: #334155;
                     -fx-border-width: 1 0 0 0;">

            <Circle radius="5" fx:id="statusIndicator" style="-fx-fill: #10b981;"/>
            <Label fx:id="lblStatus" text="Enter vehicle details to check compatibility"
                   style="-fx-text-fill: #cbd5e1;
                          -fx-font-size: 12px;
                          -fx-font-weight: 500;">
            </Label>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Compatible parts database: 50+ parts available"
                   style="-fx-text-fill: #64748b;
                          -fx-font-size: 11px;">
            </Label>
        </HBox>
    </bottom>

</BorderPane>
