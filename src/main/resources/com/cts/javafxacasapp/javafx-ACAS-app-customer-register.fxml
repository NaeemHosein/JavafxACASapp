<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<StackPane prefHeight="720" prefWidth="1280" style="-fx-background-color: #0d1520;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cts.javafxacasapp.RegisterCustomerController">

   <HBox alignment="CENTER" spacing="80" style="-fx-padding: 40 100 40 100;">

      <!-- LEFT SIDE -->
      <VBox alignment="TOP_LEFT" spacing="20" HBox.hgrow="ALWAYS">

         <VBox spacing="0">
            <ImageView fitHeight="200.0" fitWidth="200.0">
               <image>
                  <Image url="@../../../img/ACAS.png" />
               </image>
            </ImageView>
            <Label style="-fx-font-family: 'Arial Black'; -fx-font-size: 40; -fx-text-fill: white; -fx-font-style: italic;" text="AUTOMOTIVE" />
            <Text style="-fx-font-family: 'Arial Black'; -fx-font-size: 40; -fx-fill: transparent; -fx-stroke: #cc2200; -fx-stroke-width: 1.5;" text="COMPONENT" />
            <Label style="-fx-font-family: 'Arial Black'; -fx-font-size: 40; -fx-text-fill: white; -fx-font-style: italic;" text="ADVISORY" />
            <Text style="-fx-font-family: 'Arial Black'; -fx-font-size: 40; -fx-fill: transparent; -fx-stroke: #cc2200; -fx-stroke-width: 1.5;" text="SYSTEM" />
         </VBox>

         <Label maxWidth="380" style="-fx-font-size: 13; -fx-text-fill: #a0a8b8;" text="Register as a certified mechanic to access diagnostic tools, part recommendations, and vehicle advisory features." wrapText="true" />

      </VBox>

      <!-- RIGHT SIDE -->
      <VBox maxWidth="460" prefWidth="440" style="-fx-background-color: #121823; -fx-padding: 30; -fx-background-radius: 16; -fx-border-radius: 16; -fx-border-color: rgba(255,255,255,0.08);">

         <VBox spacing="5">
            <Label style="-fx-font-size: 20; -fx-text-fill: white; -fx-font-weight: bold;" text="REGISTRATION" />

                  <HBox spacing="8" style="-fx-background-color: rgba(204,34,0,0.12); -fx-border-color: #cc2200; -fx-padding: 10; -fx-background-radius: 8; -fx-border-radius: 8;">
               <Label text="🤝" />
               <VBox>
                  <Label style="-fx-text-fill: #cc2200; -fx-font-weight: bold;" text="CUSTOMER ACCOUNT" />
                  <Label style="-fx-text-fill: #6b7891; -fx-font-size: 11;" text="Create your basic account" />
               </VBox>
            </HBox>
         </VBox>
         <VBox prefHeight="200.0" prefWidth="100.0">
            <children>
      
                     <!-- PERSONAL -->
               <Label style="-fx-text-fill: #cc2200; -fx-font-size: 10; -fx-padding: 10 0 5 0;" text="PERSONAL INFORMATION" />
      
                     <TextField fx:id="fullNameField" promptText="Full Name (first name last name)">
                  <VBox.margin>
                     <Insets top="5.0" />
                  </VBox.margin>
               </TextField>
               <TextField fx:id="usernameField" promptText="Username">
                  <VBox.margin>
                     <Insets top="5.0" />
                  </VBox.margin>
               </TextField>
               <PasswordField fx:id="passwordField" promptText="Password">
                  <VBox.margin>
                     <Insets top="5.0" />
                  </VBox.margin>
               </PasswordField>
               <TextField fx:id="emailField" promptText="Email">
                  <VBox.margin>
                     <Insets top="5.0" />
                  </VBox.margin>
               </TextField>
      
                     <!-- ERROR -->
               <Label fx:id="errorLabel" textFill="red" visible="false" />
               <VBox maxWidth="800" spacing="10.0" style="-fx-background-color: #1e293b;                              -fx-background-radius: 12;                              -fx-padding: 30;                              -fx-border-color: #334155;                              -fx-border-width: 1;                              -fx-border-radius: 12;">
                  <children>
                     <Label style="-fx-text-fill: #ef4444;                                   -fx-font-size: 14px;                                   -fx-font-weight: bold;                                   -fx-letter-spacing: 1.5;" text="VEHICLE INFORMATION" />
                     <Separator style="-fx-background-color: #334155;" />
                     <GridPane hgap="20" vgap="18">
                        <children>
                           <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                              <children>
                                 <Label style="-fx-text-fill: #cbd5e1;                                           -fx-font-size: 12px;                                           -fx-font-weight: 600;" text="Make" />
                                 <ComboBox fx:id="cmbMake" prefWidth="250" promptText="Select make" style="-fx-background-color: #0f172a;                                             -fx-text-fill: #e2e8f0;                                             -fx-border-color: #475569;                                             -fx-border-radius: 8;                                             -fx-background-radius: 8;" />
                              </children>
                           </VBox>
                           <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                              <children>
                                 <Label style="-fx-text-fill: #cbd5e1;                                           -fx-font-size: 12px;                                           -fx-font-weight: 600;" text="Model" />
                                 <ComboBox fx:id="cmbModel" prefWidth="250" promptText="Select model" style="-fx-background-color: #0f172a;                                             -fx-text-fill: #e2e8f0;                                             -fx-border-color: #475569;                                             -fx-border-radius: 8;                                             -fx-background-radius: 8;" />
                              </children>
                           </VBox>
                           <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="1">
                              <children>
                                 <Label style="-fx-text-fill: #cbd5e1;                                           -fx-font-size: 12px;                                           -fx-font-weight: 600;" text="Year" />
                                 <ComboBox fx:id="cmbYear" prefWidth="250" promptText="Select year" style="-fx-background-color: #0f172a;                                             -fx-text-fill: #e2e8f0;                                             -fx-border-color: #475569;                                             -fx-border-radius: 8;                                             -fx-background-radius: 8;" />
                              </children>
                           </VBox>
                           <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="1">
                              <children>
                                 <Label style="-fx-text-fill: #cbd5e1;                                           -fx-font-size: 12px;                                           -fx-font-weight: 600;" text="Engine Type" />
                                 <ComboBox fx:id="cmbEngineType" prefWidth="250" promptText="Select engine" style="-fx-background-color: #0f172a;                                             -fx-text-fill: #e2e8f0;                                             -fx-border-color: #475569;                                             -fx-border-radius: 8;                                             -fx-background-radius: 8;" />
                              </children>
                           </VBox>
                        </children>
                        <columnConstraints>
                           <ColumnConstraints />
                           <ColumnConstraints />
                        </columnConstraints>
                        <rowConstraints>
                           <RowConstraints />
                           <RowConstraints />
                        </rowConstraints>
                     </GridPane>
                  </children>
                  <VBox.margin>
                     <Insets top="1.0" />
                  </VBox.margin>
               </VBox>
            </children>
         </VBox>
         <HBox prefHeight="54.0" prefWidth="364.0" spacing="10.0">
            <children>
               <Button fx:id="loginButton" onAction="#handleRegister" prefHeight="48.0" prefWidth="185.0" style="-fx-background-color: linear-gradient(to right, #cc2200, #ff3300);                                -fx-text-fill: #ffffff; -fx-font-family: 'Arial Black';                                -fx-font-size: 14px; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;" text="CREATE ACCOUNT" />
               <Button fx:id="registerButton1" onAction="#handleBack" prefHeight="48.0" prefWidth="185.0" style="-fx-background-color: transparent; -fx-border-color: #3a4a65;                                -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8;                                -fx-text-fill: #a0a8b8; -fx-font-family: 'Arial Black';                                -fx-font-size: 13px; -fx-cursor: hand;" text="BACK TO LOGIN" />
            </children>
            <VBox.margin>
               <Insets top="10.0" />
            </VBox.margin>
         </HBox>

      </VBox>

   </HBox>

</StackPane>
