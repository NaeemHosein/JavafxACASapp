<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="750.0" prefWidth="880.0" style="-fx-background-color: #0f172a;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cts.javafxacasapp.DiagnosticInputController">

    <!-- Top Navigation Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="25.0" style="-fx-background-color: #1e293b;                      -fx-padding: 20 30;                      -fx-border-color: #ef4444;                      -fx-border-width: 0 0 2 0;">

            <!-- Back Button -->
            <Button onAction="#handleBack" style="-fx-background-color: transparent;                            -fx-text-fill: #94a3b8;                            -fx-border-color: #334155;                            -fx-border-radius: 8;                            -fx-background-radius: 8;                            -fx-padding: 10 20;                            -fx-cursor: hand;                            -fx-font-size: 13px;                            -fx-font-weight: 600;" text="← Back to Dashboard">
            </Button>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Title -->
            <VBox alignment="CENTER" spacing="2">
                <Label style="-fx-text-fill: #ef4444;                               -fx-font-size: 20px;                               -fx-font-weight: bold;                               -fx-letter-spacing: 2px;" text="NEW DIAGNOSTIC">
                </Label>
                <Label style="-fx-text-fill: #64748b;                               -fx-font-size: 11px;" text="Enter vehicle and diagnostic information">
                </Label>
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <Label fx:id="lblUser" style="-fx-text-fill: #cbd5e1;                           -fx-font-size: 13px;" text="Guest User">
            </Label>
         <Label fx:id="lblRole" style="-fx-text-fill: #cbd5e1;                           -fx-font-size: 13px;" text="Role" />
        </HBox>
    </top>

    <!-- Bottom Status Bar -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #1e293b;                      -fx-padding: 15 30;                      -fx-border-color: #334155;                      -fx-border-width: 1 0 0 0;">

            <Circle radius="5" style="-fx-fill: #10b981;" />
            <Label fx:id="lblStatus" style="-fx-text-fill: #cbd5e1;                           -fx-font-size: 12px;                           -fx-font-weight: 500;" text="Ready to diagnose">
            </Label>

            <Region HBox.hgrow="ALWAYS" />
        </HBox>
    </bottom>
   <right>
        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: #0f172a; -fx-background: #0f172a;" BorderPane.alignment="CENTER">
            <VBox alignment="TOP_CENTER" prefWidth="744.0" spacing="30.0">
                <padding>
                    <Insets bottom="40.0" left="60.0" right="150.0" top="40.0" />
                </padding>

                <!-- Vehicle Information Section -->
                <VBox maxWidth="800" spacing="20" style="-fx-background-color: #1e293b;                              -fx-background-radius: 12;                              -fx-padding: 30;                              -fx-border-color: #334155;                              -fx-border-width: 1;                              -fx-border-radius: 12;">

                    <Label style="-fx-text-fill: #ef4444;                                   -fx-font-size: 14px;                                   -fx-font-weight: bold;                                   -fx-letter-spacing: 1.5;" text="VEHICLE INFORMATION">
                    </Label>

                    <Separator style="-fx-background-color: #334155;" />

                    <GridPane hgap="20" vgap="18">
                        <!-- Make -->
                        <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label style="-fx-text-fill: #cbd5e1;                                           -fx-font-size: 12px;                                           -fx-font-weight: 600;" text="Make">
                            </Label>
                            <ComboBox fx:id="cmbMake" prefWidth="250" promptText="Select make" style="-fx-background-color: #0f172a;                                             -fx-text-fill: #e2e8f0;                                             -fx-border-color: #475569;                                             -fx-border-radius: 8;                                             -fx-background-radius: 8;">
                            </ComboBox>
                        </VBox>

                        <!-- Model -->
                        <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label style="-fx-text-fill: #cbd5e1;                                           -fx-font-size: 12px;                                           -fx-font-weight: 600;" text="Model">
                            </Label>
                            <ComboBox fx:id="cmbModel" prefWidth="250" promptText="Select model" style="-fx-background-color: #0f172a;                                             -fx-text-fill: #e2e8f0;                                             -fx-border-color: #475569;                                             -fx-border-radius: 8;                                             -fx-background-radius: 8;">
                            </ComboBox>
                        </VBox>

                        <!-- Year -->
                        <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label style="-fx-text-fill: #cbd5e1;                                           -fx-font-size: 12px;                                           -fx-font-weight: 600;" text="Year">
                            </Label>
                            <ComboBox fx:id="cmbYear" prefWidth="250" promptText="Select year" style="-fx-background-color: #0f172a;                                             -fx-text-fill: #e2e8f0;                                             -fx-border-color: #475569;                                             -fx-border-radius: 8;                                             -fx-background-radius: 8;">
                            </ComboBox>
                        </VBox>

                        <!-- Engine Type -->
                        <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label style="-fx-text-fill: #cbd5e1;                                           -fx-font-size: 12px;                                           -fx-font-weight: 600;" text="Engine Type">
                            </Label>
                            <ComboBox fx:id="cmbEngineType" prefWidth="250" promptText="Select engine" style="-fx-background-color: #0f172a;                                             -fx-text-fill: #e2e8f0;                                             -fx-border-color: #475569;                                             -fx-border-radius: 8;                                             -fx-background-radius: 8;">
                            </ComboBox>
                        </VBox>
                  <columnConstraints>
                     <ColumnConstraints />
                     <ColumnConstraints />
                  </columnConstraints>
                  <rowConstraints>
                     <RowConstraints />
                     <RowConstraints />
                  </rowConstraints>
                    </GridPane>
                </VBox>

                <!-- Diagnostic Information Section -->
                <VBox maxWidth="800" spacing="20" style="-fx-background-color: #1e293b;                              -fx-background-radius: 12;                              -fx-padding: 30;                              -fx-border-color: #334155;                              -fx-border-width: 1;                              -fx-border-radius: 12;">

                    <Label style="-fx-text-fill: #ef4444;                                   -fx-font-size: 14px;                                   -fx-font-weight: bold;                                   -fx-letter-spacing: 1.5;" text="DIAGNOSTIC INFORMATION">
                    </Label>

                    <Separator style="-fx-background-color: #334155;" />

                    <!-- Symptom -->
                    <VBox spacing="8" />

                    <!-- Diagnostic Code -->
                    <VBox spacing="8">
                        <Label style="-fx-text-fill: #cbd5e1;                                       -fx-font-size: 12px;                                       -fx-font-weight: 600;" text="Diagnostic Trouble Code (DTC)">
                        </Label>
                        <HBox spacing="15">
                            <ComboBox fx:id="cmbDiagnosticCode" editable="true" prefHeight="27.0" prefWidth="353.0" promptText="Select or enter diagnostic code (e.g., P0300)" style="-fx-background-color: #0f172a;                                             -fx-text-fill: #e2e8f0;                                             -fx-border-color: #475569;                                             -fx-border-radius: 8;                                             -fx-background-radius: 8;">
                            </ComboBox>
                            <Button onAction="#handleClearCode" prefHeight="37.0" prefWidth="139.0" style="-fx-background-color: #334155;                                            -fx-text-fill: #94a3b8;                                            -fx-border-radius: 8;                                            -fx-background-radius: 8;                                            -fx-padding: 10 20;                                            -fx-cursor: hand;                                            -fx-font-size: 12px;" text="Clear Code">
                            </Button>
                        </HBox>
                    </VBox>

                    <!-- Additional Notes -->
                    <VBox spacing="8" />
                </VBox>

                <!-- Action Buttons -->
                <HBox alignment="CENTER" maxWidth="800" spacing="15">
                    <Button onAction="#handleGenerateDiagnosis" prefHeight="50" prefWidth="350" style="-fx-background-color: #ef4444;                                    -fx-text-fill: white;                                    -fx-border-radius: 10;                                    -fx-background-radius: 10;                                    -fx-cursor: hand;                                    -fx-font-size: 15px;                                    -fx-font-weight: bold;                                    -fx-effect: dropshadow(gaussian, rgba(239,68,68,0.4), 15, 0, 0, 5);" text="Generate Diagnosis">
                    </Button>

                    <Button onAction="#handleReset" prefHeight="50" prefWidth="170" style="-fx-background-color: transparent;                                    -fx-text-fill: #94a3b8;                                    -fx-border-color: #475569;                                    -fx-border-width: 2;                                    -fx-border-radius: 10;                                    -fx-background-radius: 10;                                    -fx-cursor: hand;                                    -fx-font-size: 14px;                                    -fx-font-weight: 600;" text="Reset Form">
                    </Button>
                </HBox>

            </VBox>
        </ScrollPane>
   </right>

</BorderPane>
