<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane prefHeight="750.0" prefWidth="1100.0" style="-fx-background-color: #121823;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cts.javafxacasapp.DashboardController">

    <!-- Top Navigation Bar - Glass Morphism Style -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="25.0" style="-fx-background-color: white; -fx-padding: 20 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);">

            <!-- Logo/Brand -->
            <HBox alignment="CENTER" spacing="12">
            <ImageView fitHeight="53.0" fitWidth="53.0">
               <image>
                  <Image url="@../../../img/ACAS.png" />
               </image>
            </ImageView>
                <VBox prefHeight="53.0" prefWidth="226.0" spacing="0">
                    <Label style="-fx-text-fill: #1a1a2e;                                   -fx-font-size: 22px;                                   -fx-font-weight: bold;                                   -fx-font-family: 'Segoe UI', sans-serif;" text="ACAS">
                    </Label>
                    <Label prefWidth="219.0" style="-fx-text-fill: #6b7280;                                   -fx-font-size: 10px;                                   -fx-font-weight: 500;" text="Automotive Component Diagnostic System">
                    </Label>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <!-- User Info -->
            <HBox alignment="CENTER" spacing="18" style="-fx-background-color: #f3f4f6;                          -fx-background-radius: 25;                          -fx-padding: 8 20;">
                <Label style="-fx-font-size: 18px;" text="👤" />
                <Label fx:id="lblWelcome" style="-fx-text-fill: #374151;                               -fx-font-size: 14px;                               -fx-font-weight: 600;" text="Welcome, Mechanic">
                </Label>
            </HBox>

            <Button onAction="#handleLogout" style="-fx-background-color: #fee2e2;                            -fx-text-fill: #dc2626;                            -fx-border-color: transparent;                            -fx-background-radius: 8;                            -fx-padding: 10 24;                            -fx-cursor: hand;                            -fx-font-size: 13px;                            -fx-font-weight: 600;" text="Logout">
            </Button>
        </HBox>
    </top>

    <!-- Main Content Area -->
    <center>
        <VBox alignment="TOP_CENTER" spacing="35.0">
            <padding>
                <Insets bottom="45.0" left="60.0" right="60.0" top="45.0" />
            </padding>

            <!-- Welcome Header -->
            <VBox alignment="CENTER" spacing="8">
                <Label style="-fx-text-fill: #111827;                               -fx-font-size: 34px;                               -fx-font-weight: bold;" text="Dashboard">
                </Label>
                <Label style="-fx-text-fill: #6b7280;                               -fx-font-size: 15px;" text="Choose what you'd like to do today">
                </Label>
            </VBox>

            <!-- Modern Cards Grid -->
            <GridPane alignment="CENTER" hgap="20.0" vgap="20.0">

                <!-- Card 1: New Diagnostic -->
                <VBox alignment="TOP_LEFT" onMouseClicked="#handleNewDiagnostic" prefHeight="190" prefWidth="230" spacing="18" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 28; -fx-cursor: hand; -fx-border-color: red; -fx-border-width: 1; -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 8, 0, 0, 2);" GridPane.columnIndex="0" GridPane.rowIndex="0">

                    <HBox alignment="CENTER_LEFT" spacing="12">
                  <ImageView fitHeight="52.0" fitWidth="52.0">
                     <image>
                        <Image url="@../../../img/DiagnosticIcon.png" />
                     </image>
                  </ImageView>
                    </HBox>

                    <VBox spacing="6">
                        <Label style="-fx-text-fill: #111827;                                       -fx-font-size: 18px;                                       -fx-font-weight: bold;" text="New Diagnostic">
                        </Label>
                        <Label style="-fx-text-fill: #6b7280;                                       -fx-font-size: 13px;" text="Start a comprehensive vehicle diagnosis" wrapText="true">
                        </Label>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS" />

                    <Label style="-fx-text-fill: #667eea;                                   -fx-font-size: 13px;                                   -fx-font-weight: 600;" text="Start →">
                    </Label>
                </VBox>

                <!-- Card 2: View Reports -->
                <VBox alignment="TOP_LEFT" onMouseClicked="#handleViewReports" prefHeight="190" prefWidth="230" spacing="18" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 28; -fx-cursor: hand; -fx-border-color: red; -fx-border-width: 1; -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 8, 0, 0, 2);" GridPane.columnIndex="1" GridPane.rowIndex="0">

                    <HBox alignment="CENTER_LEFT" spacing="12">
                  <ImageView fitHeight="52.0" fitWidth="52.0">
                     <image>
                        <Image url="@../../../img/ViewReportIcon.png" />
                     </image>
                  </ImageView>
                    </HBox>

                    <VBox spacing="6">
                        <Label style="-fx-text-fill: #111827;                                       -fx-font-size: 18px;                                       -fx-font-weight: bold;" text="View Reports">
                        </Label>
                        <Label style="-fx-text-fill: #6b7280;                                       -fx-font-size: 13px;" text="Browse historical diagnostic reports" wrapText="true">
                        </Label>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS" />

                    <Label style="-fx-text-fill: #f093fb;                                   -fx-font-size: 13px;                                   -fx-font-weight: 600;" text="View →">
                    </Label>
                </VBox>

                <!-- Card 3: Part Check -->
                <VBox alignment="TOP_LEFT" onMouseClicked="#handlePartCheck" prefHeight="190" prefWidth="230" spacing="18" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 28; -fx-cursor: hand; -fx-border-color: red; -fx-border-width: 1; -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 8, 0, 0, 2);" GridPane.columnIndex="2" GridPane.rowIndex="0">

                    <HBox alignment="CENTER_LEFT" spacing="12">
                  <ImageView fitHeight="52.0" fitWidth="52.0">
                     <image>
                        <Image url="@../../../img/PartCompatibilityIcon.png" />
                     </image>
                  </ImageView>
                    </HBox>

                    <VBox spacing="6">
                        <Label style="-fx-text-fill: #111827;                                       -fx-font-size: 18px;                                       -fx-font-weight: bold;" text="Part Compatibility">
                        </Label>
                        <Label style="-fx-text-fill: #6b7280;                                       -fx-font-size: 13px;" text="Verify component compatibility" wrapText="true">
                        </Label>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS" />

                    <Label style="-fx-text-fill: #4facfe;                                   -fx-font-size: 13px;                                   -fx-font-weight: 600;" text="Check →">
                    </Label>
                </VBox>

                <!-- Card 4: Report Issue -->
                <VBox alignment="TOP_LEFT" onMouseClicked="#handleReportIssue" prefHeight="190" prefWidth="230" spacing="18" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 28; -fx-cursor: hand; -fx-border-color: red; -fx-border-width: 1; -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 8, 0, 0, 2);" GridPane.columnIndex="0" GridPane.rowIndex="1">

                    <HBox alignment="CENTER_LEFT" spacing="12">
                  <ImageView fitHeight="52.0" fitWidth="64.0">
                     <image>
                        <Image url="@../../../img/ReportIssueIcon.png" />
                     </image>
                  </ImageView>
                    </HBox>

                    <VBox spacing="6">
                        <Label style="-fx-text-fill: #111827;                                       -fx-font-size: 18px;                                       -fx-font-weight: bold;" text="Report Issue">
                        </Label>
                        <Label style="-fx-text-fill: #6b7280;                                       -fx-font-size: 13px;" text="Flag incorrect diagnostic data" wrapText="true">
                        </Label>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS" />

                    <Label style="-fx-text-fill: #fa709a;                                   -fx-font-size: 13px;                                   -fx-font-weight: 600;" text="Report →">
                    </Label>
                </VBox>

                <!-- Admin Section Cards (Hidden by default) -->
                <!-- Card 5: Manage Rules -->
                <VBox fx:id="cardManageRules" alignment="TOP_LEFT" managed="false" onMouseClicked="#handleManageRules" prefHeight="190" prefWidth="230" spacing="18" style="-fx-background-color: white;                              -fx-background-radius: 16;                              -fx-padding: 28;                              -fx-cursor: hand;                              -fx-border-color: #fecaca;                              -fx-border-width: 2;                              -fx-border-radius: 16;                              -fx-effect: dropshadow(gaussian, rgba(220,38,38,0.1), 12, 0, 0, 3);" visible="false" GridPane.columnIndex="1" GridPane.rowIndex="1">

                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Rectangle arcHeight="12" arcWidth="12" height="52" style="-fx-fill: linear-gradient(135deg, #ff6b6b 0%, #ee5a6f 100%);" width="52" />
                        <Label style="-fx-font-size: 26px;                                       -fx-translate-x: -64;                                       -fx-translate-y: 2;" text="🔧" />
                    </HBox>

                    <VBox spacing="6">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label style="-fx-text-fill: #111827;                                           -fx-font-size: 18px;                                           -fx-font-weight: bold;" text="Manage Rules">
                            </Label>
                            <Label style="-fx-background-color: #fee2e2;                                           -fx-text-fill: #dc2626;                                           -fx-font-size: 9px;                                           -fx-font-weight: bold;                                           -fx-padding: 3 8;                                           -fx-background-radius: 4;" text="ADMIN">
                            </Label>
                        </HBox>
                        <Label style="-fx-text-fill: #6b7280;                                       -fx-font-size: 13px;" text="Configure diagnostic rules" wrapText="true">
                        </Label>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS" />

                    <Label style="-fx-text-fill: #ff6b6b;                                   -fx-font-size: 13px;                                   -fx-font-weight: 600;" text="Manage →">
                    </Label>
                </VBox>

                <!-- Card 6: Review Feedback -->
                <VBox fx:id="cardReviewFeedback" alignment="TOP_LEFT" managed="false" onMouseClicked="#handleReviewFeedback" prefHeight="190" prefWidth="230" spacing="18" style="-fx-background-color: white;                              -fx-background-radius: 16;                              -fx-padding: 28;                              -fx-cursor: hand;                              -fx-border-color: #fecaca;                              -fx-border-width: 2;                              -fx-border-radius: 16;                              -fx-effect: dropshadow(gaussian, rgba(220,38,38,0.1), 12, 0, 0, 3);" visible="false" GridPane.columnIndex="2" GridPane.rowIndex="1">

                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Rectangle arcHeight="12" arcWidth="12" height="52" style="-fx-fill: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);" width="52" />
                        <Label style="-fx-font-size: 26px;                                       -fx-translate-x: -64;                                       -fx-translate-y: 2;" text="💬" />
                    </HBox>

                    <VBox spacing="6">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label style="-fx-text-fill: #111827;                                           -fx-font-size: 18px;                                           -fx-font-weight: bold;" text="Review Feedback">
                            </Label>
                            <Label style="-fx-background-color: #fee2e2;                                           -fx-text-fill: #dc2626;                                           -fx-font-size: 9px;                                           -fx-font-weight: bold;                                           -fx-padding: 3 8;                                           -fx-background-radius: 4;" text="ADMIN">
                            </Label>
                        </HBox>
                        <Label style="-fx-text-fill: #6b7280;                                       -fx-font-size: 13px;" text="Review mechanic submissions" wrapText="true">
                        </Label>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS" />

                    <Label style="-fx-text-fill: #a8edea;                                   -fx-font-size: 13px;                                   -fx-font-weight: 600;" text="Review →">
                    </Label>
                </VBox>
            <columnConstraints>
               <ColumnConstraints />
               <ColumnConstraints />
               <ColumnConstraints />
            </columnConstraints>
            <rowConstraints>
               <RowConstraints />
               <RowConstraints />
            </rowConstraints>

            </GridPane>

        </VBox>
    </center>

    <!-- Bottom Status Bar -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: white;                      -fx-padding: 16 30;                      -fx-border-color: #e5e7eb;                      -fx-border-width: 1 0 0 0;">

            <HBox alignment="CENTER" spacing="8">
                <Circle radius="4" style="-fx-fill: #10b981;" />
                <Label fx:id="lblStatus" style="-fx-text-fill: #059669;                               -fx-font-size: 12px;                               -fx-font-weight: 600;" text="Connected">
                </Label>
            </HBox>

            <Region HBox.hgrow="ALWAYS" />
        </HBox>
    </bottom>

</BorderPane>
