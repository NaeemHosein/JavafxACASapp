<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane prefHeight="750.0" prefWidth="1100.0" style="-fx-background-color: #121823;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cts.javafxacasapp.DashboardController">

    <!-- Top Navigation Bar - Glass Morphism Style -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="25.0" style="-fx-background-color: white; -fx-padding: 20 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);">

            <!-- Logo/Brand -->
            <HBox alignment="CENTER" spacing="12">
            <ImageView fitHeight="53.0" fitWidth="53.0">
               <image>
                  <Image url="@../../../img/ACAS.png" />
               </image>
            </ImageView>
                <VBox prefHeight="58.0" prefWidth="402.0" spacing="0">
                    <Label style="-fx-text-fill: rgba(255, 107, 74, 1); -fx-font-size: 30px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI', sans-serif;" text="ACAS">
                    </Label>
                    <Label prefHeight="30.0" prefWidth="392.0" style="-fx-text-fill: #6b7280; -fx-font-size: 20px; -fx-font-weight: 500;" text="Automotive Component Diagnostic System">
                    </Label>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <!-- User Info -->
            <HBox alignment="CENTER" spacing="18" style="-fx-background-color: #f3f4f6;                          -fx-background-radius: 25;                          -fx-padding: 8 20;">
                <Label style="-fx-font-size: 18px;" text="👤" />
                <Label fx:id="lblWelcome" style="-fx-text-fill: #374151;                               -fx-font-size: 14px;                               -fx-font-weight: 600;" text="Welcome Mechanic">
                </Label>
            </HBox>

            <Button onAction="#handleLogout" style="-fx-background-color: #fee2e2;                            -fx-text-fill: #dc2626;                            -fx-border-color: transparent;                            -fx-background-radius: 8;                            -fx-padding: 10 24;                            -fx-cursor: hand;                            -fx-font-size: 13px;                            -fx-font-weight: 600;" text="Logout">
            </Button>
        </HBox>
    </top>

    <!-- Main Content Area -->
    <center>
        <VBox alignment="TOP_CENTER" spacing="35.0" style="-fx-background-color: rgba(8, 10, 15, 1);">
            <padding>
                <Insets bottom="45.0" left="60.0" right="60.0" top="45.0" />
            </padding>

            <!-- Welcome Header -->
            <VBox alignment="CENTER" spacing="8">
                <Label style="-fx-text-fill: rgba(255, 107, 74, 1); -fx-font-size: 34px; -fx-font-weight: bold;" text="Mechanic Dashboard">
                </Label>
                <Label style="-fx-text-fill: #6b7280;                               -fx-font-size: 15px;" text="Choose what you'd like to do today">
                </Label>
            </VBox>

            <!-- Modern Cards Grid -->
            <GridPane alignment="CENTER" hgap="20.0" prefHeight="237.0" prefWidth="985.0" vgap="20.0">

                <!-- Card 1: New Diagnostic -->
                <VBox alignment="TOP_LEFT" onMouseClicked="#handleNewDiagnostic" prefHeight="190" prefWidth="230" spacing="18" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 28; -fx-cursor: hand; -fx-border-color: red; -fx-border-width: 1; -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 8, 0, 0, 2);" GridPane.columnIndex="0" GridPane.rowIndex="0">

                    <HBox alignment="CENTER_LEFT" spacing="12">
                  <ImageView fitHeight="52.0" fitWidth="52.0">
                     <image>
                        <Image url="@../../../img/DiagnosticIcon.png" />
                     </image>
                  </ImageView>
                  <VBox.margin>
                     <Insets />
                  </VBox.margin>
                    </HBox>

                    <VBox minHeight="-Infinity" prefHeight="70.0" prefWidth="172.0" spacing="6">
                        <Label style="-fx-text-fill: rgba(255, 0, 0, 0.5); -fx-font-size: 18px; -fx-font-weight: bold;" text="Get Diagnosis">
                        </Label>
                        <Label prefHeight="32.0" prefWidth="172.0" style="-fx-text-fill: black; -fx-font-size: 13px;" text="Initiate a new diagnostic test " wrapText="true">
                        </Label>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS" />
               <GridPane.margin>
                  <Insets top="50.0" />
               </GridPane.margin>
                </VBox>

                <!-- Card 2: View Reports -->
                <VBox alignment="TOP_LEFT" onMouseClicked="#handleViewReports" prefHeight="190" prefWidth="230" spacing="18" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 28; -fx-cursor: hand; -fx-border-color: red; -fx-border-width: 1; -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 8, 0, 0, 2);" GridPane.columnIndex="1" GridPane.rowIndex="0">

                    <HBox alignment="CENTER_LEFT" spacing="12">
                  <ImageView fitHeight="52.0" fitWidth="52.0">
                     <image>
                        <Image url="@../../../img/ViewReportIcon.png" />
                     </image>
                  </ImageView>
                    </HBox>

                    <VBox spacing="6">
                        <Label style="-fx-text-fill: rgba(255, 0, 0, 0.5); -fx-font-size: 18px; -fx-font-weight: bold;" text="View Reports">
                        </Label>
                        <Label style="-fx-text-fill: black; -fx-font-size: 13px;" text="Browse previous diagnostic reports" wrapText="true">
                        </Label>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS" />
               <GridPane.margin>
                  <Insets top="50.0" />
               </GridPane.margin>
                </VBox>

                <!-- Card 3: Part Check -->
                <VBox alignment="TOP_LEFT" onMouseClicked="#handlePartCheck" prefHeight="190" prefWidth="230" spacing="18.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 28; -fx-cursor: hand; -fx-border-color: red; -fx-border-width: 1; -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 8, 0, 0, 2);" GridPane.columnIndex="2" GridPane.rowIndex="0">

                    <HBox alignment="CENTER_LEFT" spacing="12">
                  <ImageView fitHeight="52.0" fitWidth="52.0">
                     <image>
                        <Image url="@../../../img/PartCompatibilityIcon.png" />
                     </image>
                  </ImageView>
                    </HBox>

                    <VBox minHeight="-Infinity" spacing="6">
                        <Label style="-fx-text-fill: rgba(255, 0, 0, 0.5); -fx-font-size: 18px; -fx-font-weight: bold;" text="Check Compatibility">
                        </Label>
                        <Label style="-fx-text-fill: black; -fx-font-size: 13px;" text="Verify part compatibility with  specific vehicle" wrapText="true">
                        </Label>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS" />
               <GridPane.margin>
                  <Insets top="50.0" />
               </GridPane.margin>
                </VBox>

            <columnConstraints>
               <ColumnConstraints />
               <ColumnConstraints />
               <ColumnConstraints />
            </columnConstraints>
            <rowConstraints>
               <RowConstraints />
               <RowConstraints />
            </rowConstraints>

            </GridPane>

        </VBox>
    </center>

    <!-- Bottom Status Bar -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: white;                      -fx-padding: 16 30;                      -fx-border-color: #e5e7eb;                      -fx-border-width: 1 0 0 0;">

            <HBox alignment="CENTER" spacing="8">
                <Circle radius="4" style="-fx-fill: #10b981;" />
                <Label fx:id="lblStatus" style="-fx-text-fill: #059669;                               -fx-font-size: 12px;                               -fx-font-weight: 600;" text="Connected">
                </Label>
            </HBox>

            <Region HBox.hgrow="ALWAYS" />
        </HBox>
    </bottom>

</BorderPane>
