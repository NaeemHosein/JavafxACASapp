<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="750.0" prefWidth="1100.0" style="-fx-background-color: #0f172a;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cts.javafxacasapp.ViewDiagnosticReportsController">

    <!-- Top Navigation Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="25.0" style="-fx-background-color: #1e293b;                      -fx-padding: 20 30;                      -fx-border-color: #ef4444;                      -fx-border-width: 0 0 2 0;">

            <Button onAction="#handleBack" style="-fx-background-color: transparent;                            -fx-text-fill: #94a3b8;                            -fx-border-color: #334155;                            -fx-border-radius: 8;                            -fx-background-radius: 8;                            -fx-padding: 10 20;                            -fx-cursor: hand;                            -fx-font-size: 13px;                            -fx-font-weight: 600;" text="← Back to Dashboard" />

            <Region HBox.hgrow="ALWAYS" />

            <VBox alignment="CENTER" spacing="2">
                <Label style="-fx-text-fill: #ef4444;                               -fx-font-size: 20px;                               -fx-font-weight: bold;                               -fx-letter-spacing: 2px;" text="DIAGNOSTIC REPORTS" />
                <Label style="-fx-text-fill: #64748b;                               -fx-font-size: 11px;" text="View and export you diagnostic reports" />
            </VBox>

            <Region HBox.hgrow="ALWAYS" />
         <Label fx:id="lblUser" style="-fx-text-fill: #cbd5e1;                           -fx-font-size: 13px;" text="Guest User" />
         <Label fx:id="lblRole" style="-fx-text-fill: #cbd5e1;                           -fx-font-size: 13px;" text="Role" />
        </HBox>
    </top>

    <!-- Main Content -->
    <center>
        <VBox spacing="20" style="-fx-background-color: #0f172a; -fx-padding: 30 60;">

            <!-- Reports Table -->
            <VBox spacing="15" style="-fx-background-color: #1e293b;                          -fx-background-radius: 12;                          -fx-padding: 25;                          -fx-border-color: #334155;                          -fx-border-width: 1;                          -fx-border-radius: 12;" VBox.vgrow="ALWAYS">

                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Label style="-fx-text-fill: #ef4444;                                   -fx-font-size: 14px;                                   -fx-font-weight: bold;                                   -fx-letter-spacing: 1.5;" text="REPORTS SUMMARY" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="lblReportCount" style="-fx-text-fill: #64748b; -fx-font-size: 12px;" text="0 reports found" />
                </HBox>

                <Separator style="-fx-background-color: #334155;" />

                <TableView fx:id="tblReports" style="-fx-background-color: #0f172a;                                   -fx-border-color: #475569;                                   -fx-border-radius: 8;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colRuleId" prefWidth="80" text="Report ID" />
                        <TableColumn fx:id="colDate" prefWidth="130" text="Date" />
                        <TableColumn fx:id="colVehicle" prefWidth="200" text="Vehicle" />
                        <TableColumn fx:id="colMechanic" prefWidth="150" text="Mechanic" />
                        <TableColumn fx:id="colIssues" prefWidth="220" text="Issues Found" />
                        <TableColumn fx:id="colPart" prefWidth="110" text="Faulty Part" />
                    </columns>
                    <placeholder>
                        <Label style="-fx-text-fill: #64748b; -fx-font-size: 13px;" text="No reports found. Try adjusting your filters." />
                    </placeholder>
                </TableView>


                <!-- Feedback Section -->
                <VBox spacing="8">
                    <Label style="-fx-text-fill: #cbd5e1; -fx-font-size: 12px;" text="SPOT AN ERROR? Tell us below and flag your report!" />

                    <TextArea fx:id="txtFeedback" prefHeight="80" promptText="Enter reason for flagging report..." style="-fx-background-color: #0f172a; -fx-text-fill: black; -fx-border-color: #475569; -fx-border-radius: 8;" wrapText="true" />
                </VBox>


                <!-- Action Buttons Row -->
                <HBox alignment="CENTER_RIGHT" spacing="12">
                    <Button onAction="#handleFlagReport" style="-fx-background-color: transparent; -fx-text-fill: red; -fx-border-color: red; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand; -fx-font-size: 13px; -fx-font-weight: 600;" text="Flag Report" />

                    <Button onAction="#handlePrintPDF" style="-fx-background-color: #ef4444;                                    -fx-text-fill: white;                                    -fx-border-radius: 8;                                    -fx-background-radius: 8;                                    -fx-padding: 10 20;                                    -fx-cursor: hand;                                    -fx-font-size: 13px;                                    -fx-font-weight: 600;" text="🖨 Get Full Report as PDF" />
                </HBox>
            </VBox>
        </VBox>
    </center>

    <!-- Bottom Status Bar -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #1e293b;                      -fx-padding: 15 30;                      -fx-border-color: #334155;                      -fx-border-width: 1 0 0 0;">
            <Circle fx:id="statusIndicator" radius="5" style="-fx-fill: #10b981;" />
            <Label fx:id="lblStatus" style="-fx-text-fill: #cbd5e1;                           -fx-font-size: 12px;                           -fx-font-weight: 500;" text="Select a report to view details or export" />
            <Region HBox.hgrow="ALWAYS" />
        </HBox>
    </bottom>

</BorderPane>
